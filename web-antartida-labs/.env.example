# URL of the external webhook receiving the contact form data
CONTACT_WEBHOOK_URL=https://hook.example.com/abc123

# Optional token to send in X-Webhook-Secret header
CONTACT_WEBHOOK_SECRET=

# Rate Limit Config
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# Salt for hashing IPs in logs
IP_HASH_SALT=change-me-in-production

# Public canonical URL for SEO/Sitemap
NEXT_PUBLIC_SITE_URL=https://antartidalabs.com

# Contact email to show in the footer
NEXT_PUBLIC_CONTACT_EMAIL=contacto@antartidalabs.com

# Node Env
NODE_ENV=development
